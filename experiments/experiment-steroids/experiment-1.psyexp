      <CodeComponent name="countdown_code" plugin="None">
        <Param val="" valType="extendedCode" updates="constant" name="Before Experiment"/>
        <Param val="" valType="extendedCode" updates="constant" name="Before JS Experiment"/>
        <Param val="" valType="extendedCode" updates="constant" name="Begin Experiment"/>
        <Param val="counter_index = inner_holes.length;&amp;#10;counter_last_update = null;&amp;#10;counter_interval = 0.5;&amp;#10;" valType="extendedCode" updates="constant" name="Begin JS Experiment"/>
        <Param val="if ((counter_index &gt; 0)) {&amp;#10;    active_holes = counter_holes.slice(0, counter_index);&amp;#10;    mvc_counter_led.setLights(active_holes, new Color(&quot;white&quot;));&amp;#10;}&amp;#10;" valType="extendedCode" updates="constant" name="Begin JS Routine"/>
        <Param val="# Countdown setup&amp;#10;cur_countdown_idx = len(INNER_HOLES)&amp;#10;cur_countdown_last_update_sec = None&amp;#10;&amp;#10;# DEBUG&amp;#10;countdown_lights.turnOffLights(&quot;all&quot;)" valType="extendedCode" updates="constant" name="Begin Routine"/>
        <Param val="Py" valType="str" updates="None" name="Code Type"/>
        <Param val="# Check if it's time to update the countdown&amp;#10;if cur_countdown_last_update_sec is None:&amp;#10;    cur_countdown_last_update_sec = t  # t is the routine timer&amp;#10;&amp;#10;if t - cur_countdown_last_update_sec &gt;= COUNTDOWN_STEP_SEC:&amp;#10;    if cur_countdown_idx &gt;= 0:&amp;#10;        # Turn off the current light&amp;#10;        countdown_lights.turnOffLights(cur_countdown_idx)&amp;#10;    else:&amp;#10;        continueRoutine = False&amp;#10;    &amp;#10;    # Decrease the number of active lights&amp;#10;    cur_countdown_idx -= 1&amp;#10;    cur_countdown_last_update_sec = t" valType="extendedCode" updates="constant" name="Each Frame"/>
        <Param val="if ((counter_last_update === null)) {&amp;#10;    counter_last_update = t;&amp;#10;}&amp;#10;if (((t - counter_last_update) &gt;= counter_interval)) {&amp;#10;    counter_index -= 1;&amp;#10;    counter_last_update = t;&amp;#10;    if ((counter_index &gt;= 0)) {&amp;#10;        mvc_counter_led.turnOffLights([counter_holes[counter_index]]);&amp;#10;    } else {&amp;#10;        continueRoutine = false;&amp;#10;    }&amp;#10;}&amp;#10;" valType="extendedCode" updates="constant" name="Each JS Frame"/>
        <Param val="" valType="extendedCode" updates="constant" name="End Experiment"/>
        <Param val="" valType="extendedCode" updates="constant" name="End JS Experiment"/>
        <Param val="" valType="extendedCode" updates="constant" name="End JS Routine"/>
        <Param val="" valType="extendedCode" updates="constant" name="End Routine"/>
        <Param val="False" valType="bool" updates="None" name="disabled"/>
        <Param val="countdown_code" valType="code" updates="None" name="name"/>
      </CodeComponent>
