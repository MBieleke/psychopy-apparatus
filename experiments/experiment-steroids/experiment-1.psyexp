      <CodeComponent name="setup_ring" plugin="None">
        <Param val="" valType="extendedCode" updates="constant" name="Before Experiment"/>
        <Param val="" valType="extendedCode" updates="constant" name="Before JS Experiment"/>
        <Param val="# Main ring parameters&amp;#10;ring_radius = 0.075  # distance of small circles from center&amp;#10;hole_radius = 0.02   # size of each small circle&amp;#10;&amp;#10;# Create the 8 hole stimuli&amp;#10;hole_stimuli = []&amp;#10;ring_center = (0.5, 0.0)&amp;#10;for i in range(NUM_DISTRACTORS):&amp;#10;    angle = np.pi - 2 * np.pi * i / NUM_DISTRACTORS&amp;#10;    x = ring_center[0] + ring_radius * np.cos(angle)&amp;#10;    y = ring_center[1] + ring_radius * np.sin(angle)&amp;#10;    circle = visual.Circle(&amp;#10;        win,&amp;#10;        radius=hole_radius,&amp;#10;        pos=(x, y),&amp;#10;        fillColor=[128, 128, 128],&amp;#10;        colorSpace='rgb255',&amp;#10;        lineColor=None,&amp;#10;    )&amp;#10;    hole_stimuli.append(circle)&amp;#10;&amp;#10;# Create the labels&amp;#10;hole_labels = []&amp;#10;for i in range(NUM_DISTRACTORS):&amp;#10;    angle = np.pi - 2 * np.pi * i / NUM_DISTRACTORS&amp;#10;    x = ring_center[0] + ring_radius * np.cos(angle)&amp;#10;    y = ring_center[1] + ring_radius * np.sin(angle)&amp;#10;    label = visual.TextStim(&amp;#10;        win,&amp;#10;        text=str(i),&amp;#10;        pos=(x, y),&amp;#10;        height=0.02,&amp;#10;        color='white',&amp;#10;        bold=True,&amp;#10;    )&amp;#10;    hole_labels.append(label)" valType="extendedCode" updates="constant" name="Begin Experiment"/>
        <Param val="ring_radius = 0.075;&amp;#10;hole_radius = 0.02;&amp;#10;hole_stimuli = [];&amp;#10;ring_center = [0.5, 0.0];&amp;#10;for (var i, _pj_c = 0, _pj_a = util.range(NUM_DISTRACTORS), _pj_b = _pj_a.length; (_pj_c &lt; _pj_b); _pj_c += 1) {&amp;#10;    i = _pj_a[_pj_c];&amp;#10;    angle = (np.pi - (((2 * np.pi) * i) / NUM_DISTRACTORS));&amp;#10;    x = (ring_center[0] + (ring_radius * np.cos(angle)));&amp;#10;    y = (ring_center[1] + (ring_radius * np.sin(angle)));&amp;#10;    circle = new visual.Circle(psychoJS.window, {&quot;radius&quot;: hole_radius, &quot;pos&quot;: [x, y], &quot;fillColor&quot;: [128, 128, 128], &quot;colorSpace&quot;: &quot;rgb255&quot;, &quot;lineColor&quot;: null});&amp;#10;    hole_stimuli.push(circle);&amp;#10;}&amp;#10;hole_labels = [];&amp;#10;for (var i, _pj_c = 0, _pj_a = util.range(NUM_DISTRACTORS), _pj_b = _pj_a.length; (_pj_c &lt; _pj_b); _pj_c += 1) {&amp;#10;    i = _pj_a[_pj_c];&amp;#10;    angle = (np.pi - (((2 * np.pi) * i) / NUM_DISTRACTORS));&amp;#10;    x = (ring_center[0] + (ring_radius * np.cos(angle)));&amp;#10;    y = (ring_center[1] + (ring_radius * np.sin(angle)));&amp;#10;    label = new visual.TextStim(psychoJS.window, {&quot;text&quot;: i.toString(), &quot;pos&quot;: [x, y], &quot;height&quot;: 0.02, &quot;color&quot;: &quot;white&quot;, &quot;bold&quot;: true});&amp;#10;    hole_labels.push(label);&amp;#10;}&amp;#10;" valType="extendedCode" updates="constant" name="Begin JS Experiment"/>
        <Param val="" valType="extendedCode" updates="constant" name="Begin JS Routine"/>
        <Param val="" valType="extendedCode" updates="constant" name="Begin Routine"/>
        <Param val="Auto-&gt;JS" valType="str" updates="None" name="Code Type"/>
        <Param val="" valType="extendedCode" updates="constant" name="Each Frame"/>
        <Param val="" valType="extendedCode" updates="constant" name="Each JS Frame"/>
