  <Flow>
    <Routine name="rr_setup"/>
    <Routine name="rr_start"/>
    <LoopInitiator loopType="TrialHandler" name="oo_mvc_type">
      <Param name="Selected rows" updates="None" val="" valType="str"/>
      <Param name="conditions" updates="None" val="[{'cond_maxforce_type': 'practice', 'cond_num_maxforce': 1, 'cond_maxforce_duration': 450}, {'cond_maxforce_type': 'calibration', 'cond_num_maxforce': 2, 'cond_maxforce_duration': 45}]" valType="str"/>
      <Param name="conditionsFile" updates="None" val="oo_mvc_type.xlsx" valType="file"/>
      <Param name="endPoints" updates="None" val="[0, 1]" valType="num"/>
      <Param name="isTrials" updates="None" val="True" valType="bool"/>
      <Param name="loopType" updates="None" val="sequential" valType="str"/>
      <Param name="nReps" updates="None" val="1" valType="num"/>
      <Param name="name" updates="None" val="oo_mvc_type" valType="code"/>
      <Param name="random seed" updates="None" val="" valType="code"/>
    </LoopInitiator>
    <LoopInitiator loopType="TrialHandler" name="oo_mvc_rep">
      <Param name="Selected rows" updates="None" val="" valType="str"/>
      <Param name="conditions" updates="None" val="[{'mvc_trial_nrepeat': 1, 'mvc_trial_duration': None}, {'mvc_trial_nrepeat': 3, 'mvc_trial_duration': 45}]" valType="str"/>
      <Param name="conditionsFile" updates="None" val="" valType="file"/>
      <Param name="endPoints" updates="None" val="[0, 1]" valType="code"/>
      <Param name="isTrials" updates="None" val="True" valType="bool"/>
      <Param name="loopType" updates="None" val="sequential" valType="str"/>
      <Param name="nReps" updates="None" val="cond_num_maxforce" valType="code"/>
      <Param name="name" updates="None" val="oo_mvc_rep" valType="code"/>
      <Param name="random seed" updates="None" val="" valType="code"/>
    </LoopInitiator>
    <Routine name="rr_countdown"/>
    <Routine name="rr_maxforce"/>
    <Routine name="rr_mvc"/>
    <LoopTerminator name="oo_mvc_rep"/>
    <LoopTerminator name="oo_mvc_type"/>
    <LoopInitiator loopType="TrialHandler" name="oo_block">
      <Param name="Selected rows" updates="None" val="" valType="str"/>
      <Param name="conditions" updates="None" val="None" valType="str"/>
      <Param name="conditionsFile" updates="None" val="" valType="file"/>
      <Param name="endPoints" updates="None" val="[0, 1]" valType="code"/>
      <Param name="isTrials" updates="None" val="True" valType="bool"/>
      <Param name="loopType" updates="None" val="random" valType="str"/>
      <Param name="nReps" updates="None" val="NUM_BLOCKS" valType="code"/>
      <Param name="name" updates="None" val="oo_block" valType="code"/>
      <Param name="random seed" updates="None" val="" valType="code"/>
    </LoopInitiator>
    <Routine name="rr_countdown"/>
    <LoopInitiator loopType="TrialHandler" name="oo_level">
      <Param name="Selected rows" updates="None" val="" valType="str"/>
      <Param name="conditions" updates="None" val="[{'cond_level_cognitive': 10, 'cond_level_physical': 0.1, 'cond_target_color_rgb255': [0, 0, 255]}, {'cond_level_cognitive': 10, 'cond_level_physical': 0.1, 'cond_target_color_rgb255': [255, 0, 0]}, {'cond_level_cognitive': 10, 'cond_level_physical': 0.1, 'cond_target_color_rgb255': [0, 255, 0]}, {'cond_level_cognitive': 20, 'cond_level_physical': 0.16, 'cond_target_color_rgb255': [0, 0, 255]}, {'cond_level_cognitive': 20, 'cond_level_physical': 0.16, 'cond_target_color_rgb255': [255, 0, 0]}, {'cond_level_cognitive': 20, 'cond_level_physical': 0.16, 'cond_target_color_rgb255': [0, 255, 0]}, {'cond_level_cognitive': 30, 'cond_level_physical': 0.22, 'cond_target_color_rgb255': [0, 0, 255]}, {'cond_level_cognitive': 30, 'cond_level_physical': 0.22, 'cond_target_color_rgb255': [255, 0, 0]}, {'cond_level_cognitive': 30, 'cond_level_physical': 0.22, 'cond_target_color_rgb255': [0, 255, 0]}, {'cond_level_cognitive': 40, 'cond_level_physical': 0.28, 'cond_target_color_rgb255': [0, 0, 255]}, {'cond_level_cognitive': 40, 'cond_level_physical': 0.28, 'cond_target_color_rgb255': [255, 0, 0]}, {'cond_level_cognitive': 40, 'cond_level_physical': 0.28, 'cond_target_color_rgb255': [0, 255, 0]}, {'cond_level_cognitive': 50, 'cond_level_physical': 0.34, 'cond_target_color_rgb255': [0, 0, 255]}, {'cond_level_cognitive': 50, 'cond_level_physical': 0.34, 'cond_target_color_rgb255': [255, 0, 0]}, {'cond_level_cognitive': 50, 'cond_level_physical': 0.34, 'cond_target_color_rgb255': [0, 255, 0]}, {'cond_level_cognitive': 60, 'cond_level_physical': 0.4, 'cond_target_color_rgb255': [0, 0, 255]}, {'cond_level_cognitive': 60, 'cond_level_physical': 0.4, 'cond_target_color_rgb255': [255, 0, 0]}, {'cond_level_cognitive': 60, 'cond_level_physical': 0.4, 'cond_target_color_rgb255': [0, 255, 0]}]" valType="str"/>
      <Param name="conditionsFile" updates="None" val="oo_level.xlsx" valType="file"/>
      <Param name="endPoints" updates="None" val="[0, 1]" valType="code"/>
      <Param name="isTrials" updates="None" val="True" valType="bool"/>
      <Param name="loopType" updates="None" val="random" valType="str"/>
      <Param name="nReps" updates="None" val="NUM_LEVELS" valType="code"/>
      <Param name="name" updates="None" val="oo_level" valType="code"/>
      <Param name="random seed" updates="None" val="" valType="code"/>
    </LoopInitiator>
    <Routine name="rr_target"/>
    <LoopInitiator loopType="TrialHandler" name="oo_palette">
      <Param name="Selected rows" updates="None" val="" valType="str"/>
      <Param name="conditions" updates="None" val="None" valType="str"/>
      <Param name="conditionsFile" updates="None" val="" valType="file"/>
      <Param name="endPoints" updates="None" val="[0, 1]" valType="code"/>
      <Param name="isTrials" updates="None" val="True" valType="bool"/>
      <Param name="loopType" updates="None" val="random" valType="str"/>
      <Param name="nReps" updates="None" val="NUM_PALETTES" valType="code"/>
      <Param name="name" updates="None" val="oo_palette" valType="code"/>
      <Param name="random seed" updates="None" val="" valType="code"/>
    </LoopInitiator>
    <Routine name="rr_trial"/>
    <LoopTerminator name="oo_palette"/>
    <Routine name="rr_dprime"/>
    <LoopInitiator loopType="TrialHandler" name="oo_slider">
      <Param name="Selected rows" updates="None" val="" valType="str"/>
      <Param name="conditions" updates="None" val="[{'cond_slider': 'cognitive'}, {'cond_slider': 'physical'}]" valType="str"/>
      <Param name="conditionsFile" updates="None" val="oo_slider.xlsx" valType="file"/>
      <Param name="endPoints" updates="None" val="[0, 1]" valType="code"/>
      <Param name="isTrials" updates="None" val="True" valType="bool"/>
      <Param name="loopType" updates="None" val="sequential" valType="str"/>
      <Param name="nReps" updates="None" val="1" valType="code"/>
      <Param name="name" updates="None" val="oo_slider" valType="code"/>
      <Param name="random seed" updates="None" val="" valType="code"/>
    </LoopInitiator>
    <Routine name="rr_rating"/>
    <LoopTerminator name="oo_slider"/>
    <LoopTerminator name="oo_level"/>
    <Routine name="blockBreak"/>
    <LoopTerminator name="oo_block"/>
    <Routine name="domainBreak"/>
  </Flow>
</PsychoPy2experiment>
